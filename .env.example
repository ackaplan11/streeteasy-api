# Resend API — https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_KEY_HERE

# Sender must be a Resend-verified domain address, e.g. watcher@yourdomain.com
# (For dev, you can use "onboarding@resend.dev" but the recipient must be your
# own Resend-verified account email.)
RESEND_FROM=onboarding@resend.dev

# Recipient — the email you want to receive notifications at
RESEND_TO=ac.kaplan11@gmail.com

# Optional — path to the state file (default: ./state.json)
# STATE_PATH=./state.json

# Optional — WebSocket port (default: 8787)
# WS_PORT=8787

# Optional — poll interval in milliseconds (default: 600000 = 10 min, floor: 60000)
# POLL_INTERVAL_MS=600000
